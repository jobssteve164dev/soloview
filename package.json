{
  "name": "soloview",
  "displayName": "SoloView",
  "description": "%extension.description%",
  "version": "0.1.6",
  "publisher": "SZLK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jobssteve164dev/soloview.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/soloview-market.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:soloview.sidebar",
    "onCommand:soloview.openDocument",
    "onCommand:soloview.clearRecent",
    "onCustomEditor:soloview.documentViewer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "soloview.openDocument",
        "title": "%command.open%",
        "category": "SoloView",
        "icon": "$(folder-opened)"
      },
      {
        "command": "soloview.clearRecent",
        "title": "%command.clearRecent%",
        "category": "SoloView",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "soloview-sidebar-container",
          "title": "SoloView",
          "icon": "resources/activitybar.svg"
        }
      ]
    },
    "views": {
      "soloview-sidebar-container": [
        {
          "id": "soloview.sidebar",
          "name": "%view.recent%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "soloview.sidebar",
        "contents": "%view.welcome%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "soloview.openDocument",
          "when": "view == soloview.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "soloview.clearRecent",
          "when": "view == soloview.sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "soloview.documentViewer",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          },
          {
            "filenamePattern": "*.docx"
          },
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          },
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.pptx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "tsc --noEmit && npm run build && node --test test/*.test.mjs",
    "test:host": "npm run build && xvfb-run -a node test/host/run.mjs",
    "watch": "node build.mjs --watch",
    "package": "npm run check && vsce package --no-dependencies --allow-missing-repository --no-rewrite-relative-links"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.2.4",
    "docx-preview": "^0.4.0",
    "pdfjs-dist": "^6.1.200",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
